# TANGLE Backend Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` (gitignored) at the repo root and fill in values.
# The backend loads variables via `python-dotenv` (see `backend/main.py:23`).
#
# Requirements:
#   • At least ONE LLM provider key is required (OpenRouter or Gemini).
#   • QDRANT_URL defaults to local; QDRANT_API_KEY only needed for Qdrant Cloud.
#
# Verify after setup:
#   curl http://localhost:8000/api/health/providers
#   curl http://localhost:8000/api/config

# ─── LLM Providers (at least one required) ──────────────────────
# OpenRouter — primary provider. Routes to many free models.
# Used in: free_gateway.py, vector_store.py (embeddings), browser_agent.py, main.py.
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Google Gemini — secondary provider. Free tier via Google AI Studio.
# Used in: free_gateway.py, browser_agent.py, main.py.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-REPLACE_ME

# ─── Vector Store ───────────────────────────────────────────────
# Qdrant URL — where the vector DB lives. Defaults to local Docker instance.
# Used in: vector_store.py:21 (default: http://localhost:6333).
# For Qdrant Cloud: set to https://<cluster>.qdrant.io
# QDRANT_URL=http://localhost:6333

# Qdrant API key — leave blank for local Qdrant; required for Qdrant Cloud.
# Used in: vector_store.py:22 (default: empty string).
# Get a key: https://cloud.qdrant.io → cluster details
# QDRANT_API_KEY=

# ─── Web Search ──────────────────────────────────────────────────
# Jina AI Reader — free web search & content extraction.
# Without key: 20 req/min. With key: 500 req/min + 10M free tokens.
# Used in: agent_orchestrator.py (scout search step).
# Get a free key: https://jina.ai/reader
# JINA_API_KEY=

# Exa — AI-native search. 20k free requests/month.
# Used when TANGLE_SCOUT_SOURCE=exa or exa-crawl.
# Get a free key: https://dashboard.exa.ai/api-keys
# EXA_API_KEY=

# Scout source strategy — which tools power the scout agent's web search.
# Options: jina (default), exa, crawl4ai, exa-crawl, both
#   jina       → Jina AI search only (fast, no local resources)
#   exa        → Exa AI-native search (structured results, rich metadata)
#   crawl4ai   → Jina search for URLs → Crawl4AI deep-crawls top 2-3 pages
#   exa-crawl  → Exa search for URLs → Crawl4AI deep-crawls top 2-3 pages
#   both       → Jina search + Crawl4AI crawl combined
# Crawl4AI starts a real browser per crawl — slower but richer output.
# Requires: pip install crawl4ai
TANGLE_SCOUT_SOURCE=jina

# ─── Optional: Ollama (local-only fallback) ─────────────────────
# Ollama is hardcoded to http://localhost:11434 in free_gateway.py:9
# and is NOT read from an env var. To change the host, edit free_gateway.py.
# If Ollama is unreachable AND no other provider key is set, the gateway
# will return errors. Run locally with: `ollama serve`
# OLLAMA_HOST=http://localhost:11434

# ─── Supabase (parallel cloud mirror + pgvector search) ───────
# When TANGLE_SUPABASE_ENABLED=1, every add_wiki_entry() and save_mission()
# mirrors data to Supabase alongside SQLite. SQLite stays source of truth.
# pgvector vector search activates as a fallback when Qdrant is down.
#
# Manual SQL setup (run once in Supabase SQL Editor):
#   1. CREATE EXTENSION IF NOT EXISTS vector;
#   2. Create tables (see _init_supabase DDL or run the CREATE TABLE from docs)
#   3. ALTER TABLE wiki_entries ADD COLUMN IF NOT EXISTS embedding vector(4096);
#   4. After ~100 rows exist:
#      CREATE INDEX ON wiki_entries
#        USING ivfflat (embedding vector_cosine_ops) WITH (lists = 10);
#   5. The search_wiki_entries RPC function is auto-created by _init_supabase()
#      via exec_sql RPC, or run manually from vector_store.py DDL.
#
# NOTE: If you previously ran the 1536-dim version (openai/text-embedding-3-small),
# you must drop + recreate the embedding column before re-seeding with 4096-dim:
#   ALTER TABLE wiki_entries DROP COLUMN IF EXISTS embedding;
#   ALTER TABLE wiki_entries ADD COLUMN embedding vector(4096);
# Re-seed after: `python scripts/reseed_embeddings.py`
#
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# TANGLE_SUPABASE_ENABLED=1

# ─── Embeddings ───────────────────────────────────────────────
# TANGLE_EMBEDDING_SOURCE controls how wiki text is vectorized.
#   ollama     (default) — local via Ollama, $0, requires `ollama serve`
#   openrouter          — paid via openai/text-embedding-3-small (1536 dim)
#   sha256              — deterministic hash fallback for offline-only mode
#
# Default model: qwen3-embedding:8b (4096 dim, top-5 MTEB retrieval).
# Override with TANGLE_OLLAMA_EMBED_MODEL=<model:tag> if you pulled a smaller variant.
#
# When qwen3-embedding:8b runs alongside a browser, cap GPU layers so the
# browser stays responsive:
#   OLLAMA_NUM_GPU=50
# (Ollama's default is full GPU; ~50 layers works on most 8-16GB Macs.)
#
# TANGLE_EMBEDDING_SOURCE=ollama
# TANGLE_OLLAMA_EMBED_MODEL=qwen3-embedding:8b
# OLLAMA_NUM_GPU=50
